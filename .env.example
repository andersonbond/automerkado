# Database (SQLite file lives next to prisma/schema.prisma)
DATABASE_URL="file:./dev.db"

# Optional: absolute repo root (contains `public/`, `package.json`). Use if uploads 404 in prod:
# PM2/systemd cwd differs from the app directory, or nginx must match the same path for disk writes.
# Example: AUTOMERKADO_APP_ROOT="/home/appuser/automerkado"

# Auth.js / NextAuth — generate: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Public site origin — used for sitemap, metadata, and Meta inventory CSV (link + image_link columns).
# Set in production so `npm run export:meta-inventory` writes absolute HTTPS URLs.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional: admin dashboard site-storage progress bar budget (megabytes); default 51200 (50 GB)
# ADMIN_IMAGE_STORAGE_QUOTA_MB="51200"

# Optional: baseline system/runtime allowance counted in site storage meter (megabytes); default 500
# ADMIN_SYSTEM_STORAGE_ALLOCATION_MB="500"

# Optional: bid confirmation email (SMTP)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Meta (Facebook) Pixel — NEXT_PUBLIC_ so the browser bundle can read it (Events Manager base code).
NEXT_PUBLIC_META_PIXEL_ID="1658654002119894"
